{
  "name": "hyper-dht-prom-client",
  "version": "2.2.0",
  "description": "Expose Prometheus metrics over a hyperdht server",
  "main": "index.js",
  "scripts": {
    "test": "npm run format:check && lunte && brittle-node --coverage test.js",
    "test:bare": "brittle-bare --coverage test.js",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holepunchto/hyper-dht-prom-client.git"
  },
  "keywords": [
    "prometheus",
    "prom-client",
    "hyperdht",
    "dht"
  ],
  "author": "Holepunch Inc",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/holepunchto/hyper-dht-prom-client/issues"
  },
  "homepage": "https://github.com/holepunchto/hyper-dht-prom-client#readme",
  "dependencies": {
    "b4a": "^1.6.6",
    "bare-crypto": "^1.11.2",
    "bare-os": "^3.6.2",
    "compact-encoding": "^3.0.0",
    "hyper-dht-prom-alias-rpc": "^2.2.0",
    "hypercore-id-encoding": "^1.3.0",
    "hyperdht": "^6.15.1",
    "protomux-rpc": "^1.7.0",
    "protomux-rpc-client": "^2.0.1",
    "ready-resource": "^1.1.1"
  },
  "devDependencies": {
    "bare-path": "^3.0.1",
    "bare-process": "^4.5.0",
    "bare-prom-client": "^15.1.9",
    "bare-subprocess": "^6.1.0",
    "brittle": "^4.0.2",
    "hypercore-crypto": "^3.4.2",
    "hyperswarm": "^4.8.0",
    "lunte": "^1.8.0",
    "newline-decoder": "^1.0.2",
    "prettier": "^3.8.3",
    "prettier-config-holepunch": "^2.0.0",
    "safety-catch": "^1.0.2"
  },
  "files": [
    "index.js",
    "scraper.js",
    "lib/**.js"
  ],
  "imports": {
    "crypto": {
      "bare": "bare-crypto",
      "default": "crypto"
    },
    "os": {
      "bare": "bare-os",
      "default": "os"
    },
    "child_process": {
      "bare": "bare-subprocess",
      "default": "child_process"
    },
    "path": {
      "bare": "bare-path",
      "default": "path"
    },
    "process": {
      "bare": "bare-process",
      "default": "process"
    }
  }
}
