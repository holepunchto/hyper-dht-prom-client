{
  "name": "hyper-dht-prom-client",
  "version": "2.1.1",
  "description": "Expose Prometheus metrics over a hyperdht server",
  "main": "index.js",
  "scripts": {
    "test": "npm run format:check && lunte &&  brittle --coverage test.js",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@gitlab.com/dcent-tech/hyper-dht-prom-client.git"
  },
  "keywords": [
    "prometheus",
    "prom-client",
    "hyperdht",
    "dht"
  ],
  "author": "Holepunch Inc",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://gitlab.com/dcent-tech/hyper-dht-prom-client/issues"
  },
  "homepage": "https://gitlab.com/dcent-tech/hyper-dht-prom-client#readme",
  "dependencies": {
    "b4a": "^1.6.6",
    "bare-crypto": "^1.11.2",
    "bare-os": "^3.6.2",
    "compact-encoding": "^3.0.0",
    "dht-prom-alias-rpc": "^2.0.0",
    "hypercore-id-encoding": "^1.3.0",
    "hyperdht": "^6.15.1",
    "protomux-rpc": "^1.7.0",
    "protomux-rpc-client": "^2.0.1",
    "ready-resource": "^1.1.1"
  },
  "devDependencies": {
    "brittle": "^3.5.2",
    "hypercore-crypto": "^3.4.2",
    "hyperswarm": "^4.8.0",
    "lunte": "^1.8.0",
    "newline-decoder": "^1.0.2",
    "prettier": "^3.8.3",
    "prettier-config-holepunch": "^2.0.0",
    "prom-client": "^15.1.2",
    "safety-catch": "^1.0.2"
  },
  "files": [
    "index.js",
    "scraper.js",
    "lib/**.js"
  ],
  "imports": {
    "crypto": {
      "bare": "bare-crypto",
      "default": "crypto"
    },
    "os": {
      "bare": "bare-os",
      "default": "os"
    }
  }
}
